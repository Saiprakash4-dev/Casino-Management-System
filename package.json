{
  "name": "casino-management-system",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace apps/frontend",
    "build": "npm run build --workspace apps/frontend",
    "lint": "npm run lint --workspace apps/frontend",
    "typecheck": "npm run typecheck --workspace apps/frontend",
    "start:all": "docker compose up --build"
  }
}
